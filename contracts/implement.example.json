  "mode": "implement",
  "allowed_files": ["src/**/*.py", "tests/**/*.py"],
  "forbidden_files": [".env", ".env.*", "*.key", "*.pem", "*.token", "secrets/**", "wandb/**", "outputs/**", "runs/**", "results/final/**", "paper/figures/final/**", "paper/tables/final/**"],
